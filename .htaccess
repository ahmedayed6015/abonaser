# .htaccess لبيئة PHP مع دعم مجلد dist
RewriteEngine On
Options -Indexes

# 1. إذا كان الملف موجوداً في المجلد الرئيسي، قم بتشغيله مباشرة
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. إذا كان الملف موجوداً داخل مجلد dist (مثل ملفات الـ CSS والـ JS)، قم بتوجيهه لهناك
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
RewriteRule ^(.*)$ dist/$1 [L]

# 3. توجيه كافة الطلبات البرمجية الأخرى إلى index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]
